{
  "id": "global-memory",
  "name": "Global Memory",
  "description": "Automatic narrow memory recall for every OpenClaw turn.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "engineRoot": {
        "type": "string",
        "minLength": 1
      },
      "nodeBin": {
        "type": "string",
        "minLength": 1
      },
      "minPromptChars": {
        "type": "number",
        "minimum": 1,
        "maximum": 2000
      },
      "maxResults": {
        "type": "number",
        "minimum": 1,
        "maximum": 10
      },
      "minScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "maxChars": {
        "type": "number",
        "minimum": 200,
        "maximum": 5000
      },
      "maxSnippetChars": {
        "type": "number",
        "minimum": 120,
        "maximum": 2000
      },
      "timeoutMs": {
        "type": "number",
        "minimum": 1000,
        "maximum": 30000
      },
      "userTriggersOnly": {
        "type": "boolean"
      }
    }
  }
}
